<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
		xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
		xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

	<changeSet author="vspasic" id="1.0.0-create-namespaces-table" context="identity or api">
		<preConditions onFail="MARK_RAN">
			<not>
				<tableExists tableName="namespaces" />
			</not>
		</preConditions>

		<comment>Initial namespaces table migration</comment>

		<createTable tableName="namespaces" remarks="Namespace under which artifacts and vaults would be managed.">
			<column name="id" type="bigint" autoIncrement="true">
				<constraints primaryKey="true" nullable="false" />
			</column>

			<column name="slug" type="varchar(255)">
				<constraints nullable="false" />
			</column>

			<column name="name" type="varchar(255)">
				<constraints nullable="false" />
			</column>

			<column name="description" type="text">
				<constraints nullable="true" />
			</column>

			<column name="avatar" type="varchar(255)" />

			<column name="created_at" type="timestamptz" defaultValue="NOW()">
				<constraints nullable="false" />
			</column>

			<column name="updated_at" type="timestamptz" defaultValue="NOW()">
				<constraints nullable="false" />
			</column>
		</createTable>

		<addUniqueConstraint
				tableName="namespaces"
				columnNames="slug"
				constraintName="unique_namespace"
		/>
	</changeSet>

	<changeSet author="vspasic" id="1.0.0-create-namespace-members-table" context="api">
		<preConditions onFail="MARK_RAN">
			<not>
				<tableExists tableName="namespace_members" />
			</not>
		</preConditions>

		<comment>Initial namespace members table migration</comment>

		<createTable tableName="namespace_members" remarks="User accounts that are allowed to access and manage namespaces.">
			<column name="id" type="bigint" autoIncrement="true">
				<constraints primaryKey="true" nullable="false" />
			</column>

			<column name="namespace_id" type="bigint">
				<constraints nullable="false" />
			</column>

			<column name="account_id" type="bigint">
				<constraints nullable="false" />
			</column>

			<column name="role" type="varchar(20)">
				<constraints nullable="false" />
			</column>

			<column name="since" type="timestamptz" defaultValue="NOW()">
				<constraints nullable="false" />
			</column>
		</createTable>

		<addUniqueConstraint
				tableName="namespace_members"
				columnNames="namespace_id,account_id"
				constraintName="unique_namespace_member"
		/>

		<addForeignKeyConstraint
				baseTableName="namespace_members"
				baseColumnNames="namespace_id"
				constraintName="fk_namespace_member_namespace"
				referencedTableName="namespaces"
				referencedColumnNames="id"
				onDelete="CASCADE"
		/>

		<addForeignKeyConstraint
				baseTableName="namespace_members"
				baseColumnNames="account_id"
				constraintName="fk_namespace_member_account"
				referencedTableName="accounts"
				referencedColumnNames="id"
				onDelete="CASCADE"
		/>
	</changeSet>

	<changeSet author="vspasic" id="1.0.0-create-namespace-integrations-table" context="api">
		<preConditions onFail="MARK_RAN">
			<not>
				<tableExists tableName="integrations" />
			</not>
		</preConditions>

		<comment>Initial Namespace Integrations table migration</comment>

		<createTable tableName="integrations" remarks="Third party integrations granted by the namespace owners.">
			<column name="id" type="bigint" autoIncrement="true">
				<constraints primaryKey="true" nullable="false" />
			</column>

			<column name="namespace_id" type="bigint">
				<constraints nullable="false" />
			</column>

			<column name="type" type="varchar(32)">
				<constraints nullable="false" />
			</column>

			<column name="provider" type="varchar(50)">
				<constraints nullable="false" />
			</column>

			<column name="provider_reference" type="varchar(255)">
				<constraints nullable="true" />
			</column>

			<column name="created_at" type="timestamptz" defaultValue="NOW()">
				<constraints nullable="false" />
			</column>

			<column name="updated_at" type="timestamptz" defaultValue="NOW()">
				<constraints nullable="false" />
			</column>
		</createTable>

		<addForeignKeyConstraint
				baseTableName="integrations"
				baseColumnNames="namespace_id"
				constraintName="fk_namespace_integration"
				referencedTableName="namespaces"
				referencedColumnNames="id"
				onDelete="CASCADE"
		/>
	</changeSet>

	<changeSet author="vspasic" id="1.0.0-create-invitations-table" context="api">
		<preConditions onFail="MARK_RAN">
			<not>
				<tableExists tableName="invitations" />
			</not>
		</preConditions>

		<comment>Member invitations table migration</comment>

		<createTable tableName="invitations" remarks="Table used to store namespace invitations for new team members.">
			<column name="key" type="char(32)">
				<constraints primaryKey="true" nullable="false"/>
			</column>
			<column name="namespace_id" type="bigint">
				<constraints primaryKey="true" nullable="false" />
			</column>
			<column name="sender_id" type="bigint">
				<constraints nullable="true" />
			</column>
			<column name="recipient_id" type="bigint">
				<constraints nullable="true" />
			</column>
			<column name="recipient_email" type="varchar(255)">
				<constraints nullable="false" />
			</column>
			<column name="role" type="varchar(10)">
				<constraints nullable="false" />
			</column>
			<column name="reminder_date" type="timestamptz">
				<constraints nullable="true" />
			</column>
			<column name="expiry_date" type="timestamptz">
				<constraints nullable="false" />
			</column>
			<column name="created_at" type="timestamptz" defaultValue="NOW()">
				<constraints nullable="false" />
			</column>
		</createTable>

		<addForeignKeyConstraint
				baseTableName="invitations"
				baseColumnNames="namespace_id"
				constraintName="fk_namespace_invitation"
				referencedTableName="namespaces"
				referencedColumnNames="id"
				onDelete="CASCADE"
		/>

		<addForeignKeyConstraint
				baseTableName="invitations"
				baseColumnNames="sender_id"
				constraintName="fk_invitation_sender"
				referencedTableName="accounts"
				referencedColumnNames="id"
				onDelete="SET NULL"
		/>

		<addForeignKeyConstraint
				baseTableName="invitations"
				baseColumnNames="recipient_id"
				constraintName="fk_invitation_recipient"
				referencedTableName="accounts"
				referencedColumnNames="id"
				onDelete="SET NULL"
		/>

		<addUniqueConstraint
				tableName="invitations"
				columnNames="namespace_id,recipient_email"
				constraintName="unique_namespace_invitation"
		/>
	</changeSet>

	<changeSet author="vspasic" id="1.0.0-create-services-table" context="api">
		<preConditions onFail="MARK_RAN">
			<not>
				<tableExists tableName="services" />
			</not>
		</preConditions>

		<comment>Initial services table migration</comment>

		<createTable tableName="services" remarks="The core domain aggregate representing a Spring Boot application.">
			<column name="id" type="bigint" autoIncrement="true">
				<constraints primaryKey="true" nullable="false" unique="true" />
			</column>

			<column name="namespace_id" type="bigint">
				<constraints primaryKey="true" nullable="false" />
			</column>

			<column name="slug" type="varchar(255)">
				<constraints nullable="false" />
			</column>

			<column name="name" type="varchar(255)">
				<constraints nullable="false" />
			</column>

			<column name="description" type="text">
				<constraints nullable="true" />
			</column>

			<column name="created_at" type="timestamptz" defaultValue="NOW()">
				<constraints nullable="false" />
			</column>

			<column name="updated_at" type="timestamptz" defaultValue="NOW()">
				<constraints nullable="false" />
			</column>
		</createTable>

		<addUniqueConstraint
				tableName="services"
				columnNames="namespace_id,slug"
				constraintName="unique_namespace_service"
		/>
	</changeSet>

	<changeSet author="vspasic" id="1.0.0-create-service-releases-table" context="api">
		<preConditions onFail="MARK_RAN">
			<not>
				<tableExists tableName="service_releases" />
			</not>
		</preConditions>

		<comment>Initial service releases table migration</comment>

		<createTable tableName="service_releases" remarks="Table that stores release versions for a service.">
			<column name="id" type="bigint" autoIncrement="true">
				<constraints primaryKey="true" nullable="false" unique="true" />
			</column>

			<column name="service_id" type="bigint" remarks="The services foreign key field.">
				<constraints nullable="false" />
			</column>

			<column name="version" type="text" remarks="The service version field.">
				<constraints nullable="false" />
			</column>

			<column name="state" type="varchar(32)" remarks="Stores the state of this release.">
				<constraints nullable="false" />
			</column>

			<column name="created_at" type="timestamptz" defaultValue="NOW()">
				<constraints nullable="false" />
			</column>
		</createTable>

		<addForeignKeyConstraint
				baseTableName="service_releases"
				baseColumnNames="service_id"
				constraintName="fk_service_release"
				referencedTableName="services"
				referencedColumnNames="id"
				onDelete="CASCADE"
		/>

		<addUniqueConstraint
				tableName="service_releases"
				columnNames="service_id,version"
				constraintName="unique_namespace_service_version"
		/>
	</changeSet>

	<changeSet author="vspasic" id="1.0.0-create-service-artifacts-table" context="api">
		<preConditions onFail="MARK_RAN">
			<not>
				<tableExists tableName="service_artifacts" />
			</not>
		</preConditions>

		<comment>Initial service artifacts table migration used to build service manifests</comment>

		<createTable tableName="service_artifacts" remarks="Table that stores which artifacts are used by specific service version.">
			<column name="release_id" type="bigint" remarks="The service releases foreign key field.">
				<constraints primaryKey="true" nullable="false" />
			</column>

			<column name="group_id" type="varchar" remarks="The Maven coordinate `groupId` field.">
				<constraints primaryKey="true" nullable="false" />
			</column>

			<column name="artifact_id" type="varchar" remarks="The Maven coordinate `artifactId` field.">
				<constraints primaryKey="true" nullable="false" />
			</column>

			<column name="version" type="text" remarks="The Maven coordinate `version` field.">
				<constraints primaryKey="true" nullable="false" />
			</column>
		</createTable>

		<addForeignKeyConstraint
				baseTableName="service_artifacts"
				baseColumnNames="release_id"
				constraintName="fk_service_artifact"
				referencedTableName="service_releases"
				referencedColumnNames="id"
				onDelete="CASCADE"
		/>
	</changeSet>
</databaseChangeLog>
